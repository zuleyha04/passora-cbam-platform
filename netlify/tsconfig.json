{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": ".netlify/functions-build",
    "rootDir": ".",
    "baseUrl": "."
  },
  "include": ["netlify/functions/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
