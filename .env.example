# ============================================================
# PASSORA CBAM Platform — Environment Variables
# ============================================================

# ── Client (VITE_ prefix = tarayıcıya gönderilir) ──────────
# Supabase anonimus key — sadece okuma yetkisi, RLS koruması altında
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Server / Netlify Functions (VITE_ prefix YOK = tarayıcıya gitmez) ──
# Service role key — tam yetki, sadece Netlify Functions içinde kullanılır
# Netlify Dashboard → Site Settings → Environment Variables → Add
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...   # secret!

# ── Nasıl Alınır ───────────────────────────────────────────
# 1. supabase.com → projen → Settings → API
# 2. URL             → Project URL
# 3. anon/public key → VITE_SUPABASE_ANON_KEY
# 4. service_role    → SUPABASE_SERVICE_KEY  (asla paylaşma!)
